# Environment and secrets
# =============================================================================

.env
.env.*
!.env.example

# =============================================================================
# Editor — VS Code
# Shared project config (.vscode/settings.json, extensions.json) IS tracked.
# Personal and generated files are ignored.
# =============================================================================

.vscode/*.log
.vscode/launch.json
.vscode/*.code-workspace

